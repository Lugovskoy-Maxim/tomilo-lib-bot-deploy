# Telegram (обязательно)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=-1001234567890

# API и сайт (по умолчанию: localhost:3001 и tomilo-lib.ru)
API_URL=http://localhost:3001/api
SITE_URL=https://tomilo-lib.ru
# URL, по которому доступны картинки с сервера. По умолчанию = SITE_URL.
# IMAGE_BASE_URL=https://tomilo-lib.ru
# URL облака (S3 и т.п.): если задан, при относительном coverImage пробуются оба варианта.
# IMAGE_CLOUD_BASE_URL=https://s3.regru.cloud/tomilolib

# Интервал опроса в миллисекундах (по умолчанию 300000 = 5 мин)
# POLL_INTERVAL_MS=300000

# Файл состояния (какие главы уже отправлены)
# STATE_PATH=.bot-state.json

# --- Оповещения (вкл/выкл) ---
# Новые главы (по умолчанию: 1)
# NOTIFY_NEW_CHAPTERS=1
# Новые тайтлы, добавленные сегодня (по умолчанию: 1)
# NOTIFY_NEW_TITLES=1

# Таблица лидеров: уведомлять об изменении позиций в рейтинге (по умолчанию: 0)
# NOTIFY_LEADERBOARD=1
# LEADERBOARD_SIZE=10
# LEADERBOARD_SORT=rating   или  views  (если API отдаёт просмотры)

# Юбилейные главы: оповещать при выходе 50-й, 100-й, 200-й и т.д. (по умолчанию: 0)
# NOTIFY_MILESTONE_CHAPTERS=1
# MILESTONE_CHAPTERS=50,100,200,500,1000

# Тайтл набрал за день не меньше N просмотров (по умолчанию: 0; нужна поддержка views в API)
# NOTIFY_DAILY_VIEWS=1
# DAILY_VIEWS_MIN=1000
